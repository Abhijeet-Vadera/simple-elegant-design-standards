{
  "scaleSource": "tailwind.config.js theme.extend.boxShadow",
  "tintRule": "all shadows use rgba(10,10,10, alpha) — the ink color — never pure black, except one documented full-viewport exception",
  "xs": "0 1px 2px rgba(10,10,10,0.04)",
  "sm": "0 1px 3px rgba(10,10,10,0.05), 0 1px 2px rgba(10,10,10,0.03)",
  "md": "0 4px 16px rgba(10,10,10,0.06), 0 1px 3px rgba(10,10,10,0.04)",
  "lg": "0 24px 60px rgba(10,10,10,0.14), 0 8px 24px rgba(10,10,10,0.08)",
  "focusRing": "0 0 0 3px rgba(10,10,10,0.06)",
  "componentSpecific": {
    "dropdownPanel": "0 4px 16px rgba(10,10,10,0.06)",
    "drawerPanel": "-12px 0 36px rgba(10,10,10,0.12)",
    "toggleThumb": "0 1px 2px rgba(0,0,0,0.2)",
    "avatarStackRing": "0 0 0 2px #fff",
    "segmentedActiveItem": "0 1px 2px rgba(10,10,10,0.04)"
  },
  "documentedException": {
    "fullScreenQrModal": "0 32px 80px rgba(0,0,0,0.6)",
    "note": "Pure-black, not ink-tinted — acceptable only for a genuine full-viewport takeover, not a default."
  }
}
